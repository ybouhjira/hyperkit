    "effect": "^3.19.16",
    "@ybouhjira/hyperkit-llm-pipeline": "workspace:*",
    "@ybouhjira/hyperkit-mcp": "workspace:*",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "author": "Youssef Bouhjira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ybouhjira/hyperkit.git",
