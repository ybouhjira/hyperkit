{
  "name": "@ybouhjira/hyperkit-ai-renderer",
  "version": "0.1.0",
  "description": "Transform raw data/intent into validated SolidKit UI schemas via LLM",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
