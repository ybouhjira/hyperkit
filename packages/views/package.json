{
  "name": "@ybouhjira/hyperkit-views",
  "version": "0.1.0",
  "description": "Schema-driven view generation \u2014 Effect Schema blueprints to typed SolidJS components",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:dev": "vite --config demo/vite.config.ts"
  },
  "peerDependencies": {
    "effect": "^3.0.0",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "effect": "^3.19.16",
    "jsdom": "^28.1.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  },
  "author": "Youssef Bouhjira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ybouhjira/hyperkit.git",
    "directory": "packages/views"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
